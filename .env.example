# Copy to `.env.local` and fill in from your Firebase project console.
# Without these, the app runs in guest mode (localStorage only).
#
# 1. https://console.firebase.google.com/ → Add project
# 2. Build → Authentication → Sign-in method → enable Google and Apple
# 3. Build → Firestore Database → Create database (production mode)
# 4. Project settings → General → "Your apps" → Add web app → copy the config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
